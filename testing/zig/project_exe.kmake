#version 1.0

#references
name-shared: test_sha
dir-win-shared: build\sha-
dir-lin-shared: build/sha-
name-static: test_sta
dir-win-static: build\sta-
dir-lin-static: build/sta-

#global
binaryname: test_exe
binarytype: executable
compiler: zig
customflags: export-vscode-sln

//---------------------------
// EXECUTABLE WITH SHARED LIB
//---------------------------

#profile test-exe-sha-release
buildtype: release
buildpath: "build/exe-sha-release"
sources: "src/exe"

//links: "${dir-win-shared}release/${name-shared}.lib" //WINDOWS
//links: "${dir-lin-shared}release/lib${name-shared}.so" //LINUX

//postbuildaction: copy /Y ${dir-win-shared}release\${name-shared}.dll build\exe-sha-release\${name-shared}.dll //WINDOWS
//postbuildaction: cp -f ${dir-lin-shared}release/lib${name-shared}.so build/exe-sha-release/lib${name-shared}.so //LINUX

//---------------------------
// EXECUTABLE WITH STATIC LIB
//---------------------------

#profile test-exe-sta-release
buildtype: release
buildpath: "build/exe-sta-release"
sources: "src/exe"

//links: ws2_32, mswsock, kernel32, "${dir-win-static}release\${name-static}.lib" //WINDOWS
//links: "${dir-lin-static}release/lib${name-static}.a" //LINUX
